# Copy to .env.e2e and run: pnpm run test:e2e (with ElasticMQ up)
# Stack-only e2e mocks YouTube/Wayback; no API keys required.

SQS_QUEUE_URL=http://localhost:9324/000000000000/video-backup-queue
SQS_ENDPOINT_URL=http://localhost:9324

# Optional: for full e2e with real APIs (remove axios mock in e2e test)
# YOUTUBE_DATA_API_KEY=
# WAYBACK_MACHINE_API_KEY=
